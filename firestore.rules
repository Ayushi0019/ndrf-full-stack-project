rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Role Fetching
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return isAuthenticated() && (
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserRole() == 'hq_admin') ||
        (request.auth.token.get('email', '') == "ayushikhatri994@gmail.com" && request.auth.token.get('email_verified', false) == true)
      );
    }

    function isFieldMember() {
      return isAuthenticated() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserRole() == 'field';
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'name', 'email', 'role', 'createdAt']) &&
             data.keys().size() == 5 &&
             data.uid is string &&
             data.name is string &&
             data.role in ['field', 'hq_admin'];
    }

    function isValidResource(data) {
      return data.name is string &&
             data.type in ['team', 'equipment', 'vehicle'] &&
             data.status in ['active', 'en_route', 'on_standby', 'maintenance'] &&
             data.location is map;
    }

    function isValidAlert(data) {
      return data.title is string &&
             data.message is string &&
             data.severity in ['low', 'medium', 'high', 'critical'] &&
             data.active is bool;
    }

    function isValidRequest(data) {
      return data.item is string &&
             data.quantity is number &&
             data.priority in ['low', 'medium', 'high', 'critical'] &&
             data.status in ['pending', 'approved', 'dispatched', 'delivered', 'cancelled'] &&
             data.requesterId == request.auth.uid;
    }

    function isValidInventoryItem(data) {
      return data.name is string &&
             data.category in ['medical', 'rescue', 'shelter', 'rations', 'vehicles'] &&
             data.quantity is number;
    }

    function isValidIncidentPhoto(data) {
      return data.url is string &&
             data.uploadedBy is string;
    }

    function isValidIncident(data) {
      return data.name is string &&
             data.epicenter is map &&
             data.radiusKm is number &&
             data.severity in ['low', 'medium', 'high', 'critical'] &&
             data.status in ['active', 'contained', 'resolved'];
    }

    // ===============================================================
    // Match Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data);
    }

    match /resources/{resourceId} {
      allow read: if isAuthenticated();
      allow create, update: if isAdmin() && isValidResource(request.resource.data);
      allow delete: if isAdmin();
    }

    match /alerts/{alertId} {
      allow read: if isAuthenticated();
      allow create, update: if isAdmin() && isValidAlert(request.resource.data);
      allow delete: if isAdmin();
    }

    match /requests/{requestId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidRequest(request.resource.data);
      allow update: if isAdmin() || (isAuthenticated() && request.auth.uid == resource.data.requesterId && request.resource.data.status == 'cancelled');
      allow delete: if isAdmin();
    }

    match /inventory/{itemId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() && isValidInventoryItem(request.resource.data);
    }

    match /photos/{photoId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidIncidentPhoto(request.resource.data);
      allow update, delete: if isAdmin();
    }

    match /incidents/{incidentId} {
      allow read: if isAuthenticated();
      allow create, update: if isAdmin() && isValidIncident(request.resource.data);
      allow delete: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}

