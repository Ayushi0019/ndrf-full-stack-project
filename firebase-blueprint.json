{
  "entities": {
    "User": {
      "title": "User",
      "description": "NDRF member or HQ administrator profile",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "name": { "type": "string", "description": "Full name" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["field_member", "hq_admin"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "name", "email", "role"]
    },
    "Resource": {
      "title": "Resource",
      "description": "NDRF resources including teams, equipment, and vehicles",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "type": { "type": "string", "enum": ["team", "equipment", "vehicle"] },
        "status": { "type": "string", "enum": ["active", "en_route", "on_standby", "maintenance"] },
        "location": {
          "type": "object",
          "properties": {
            "lat": { "type": "number" },
            "lng": { "type": "number" }
          },
          "required": ["lat", "lng"]
        },
        "lastUpdated": { "type": "string", "format": "date-time" },
        "assignedTo": { "type": "string", "description": "UID of the assigned field member" },
        "details": { "type": "string" }
      },
      "required": ["name", "type", "status", "location", "lastUpdated"]
    },
    "EmergencyAlert": {
      "title": "Emergency Alert",
      "description": "Critical alerts broadcasted by HQ",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "message": { "type": "string" },
        "severity": { "type": "string", "enum": ["low", "medium", "high", "critical"] },
        "timestamp": { "type": "string", "format": "date-time" },
        "active": { "type": "boolean" }
      },
      "required": ["title", "message", "severity", "timestamp", "active"]
    }
  },
  "firestore": {
    "/users/{uid}": { "schema": "User", "description": "User profiles" },
    "/resources/{resourceId}": { "schema": "Resource", "description": "NDRF resource tracking" },
    "/alerts/{alertId}": { "schema": "EmergencyAlert", "description": "Broadcasted emergency alerts" }
  }
}

