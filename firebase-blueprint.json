{
  "entities": {
    "User": {
      "title": "User",
      "description": "NDRF member or HQ administrator profile",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "name": { "type": "string", "description": "Full name" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["field_member", "hq_admin"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "name", "email", "role"]
    },
    "Resource": {
      "title": "Resource",
      "description": "NDRF resources including teams, equipment, and vehicles",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "type": { "type": "string", "enum": ["team", "equipment", "vehicle"] },
        "status": { "type": "string", "enum": ["active", "en_route", "on_standby", "maintenance"] },
        "location": {
          "type": "object",
          "properties": {
            "lat": { "type": "number" },
            "lng": { "type": "number" }
          },
          "required": ["lat", "lng"]
        },
        "lastUpdated": { "type": "string", "format": "date-time" },
        "assignedTo": { "type": "string", "description": "UID of the assigned field member" },
        "details": { "type": "string" }
      },
      "required": ["name", "type", "status", "location", "lastUpdated"]
    },
    "EmergencyAlert": {
      "title": "Emergency Alert",
      "description": "Critical alerts broadcasted by HQ",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "message": { "type": "string" },
        "severity": { "type": "string", "enum": ["low", "medium", "high", "critical"] },
        "disasterZone": { "type": "string" },
        "affectedArea": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "active": { "type": "boolean" }
      },
      "required": ["title", "message", "severity", "timestamp", "active"]
    },
    "ResourceRequest": {
      "title": "Resource Request",
      "description": "Requests for resources from field members to HQ",
      "type": "object",
      "properties": {
        "item": { "type": "string" },
        "quantity": { "type": "number" },
        "priority": { "type": "string", "enum": ["low", "medium", "high", "critical"] },
        "status": { "type": "string", "enum": ["pending", "approved", "dispatched", "delivered", "cancelled"] },
        "disasterZone": { "type": "string" },
        "affectedArea": { "type": "string" },
        "requestedBy": { "type": "string" },
        "requesterId": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "location": {
          "type": "object",
          "properties": {
            "lat": { "type": "number" },
            "lng": { "type": "number" }
          },
          "required": ["lat", "lng"]
        }
      },
      "required": ["item", "quantity", "priority", "status", "requesterId", "timestamp", "location"]
    },
    "InventoryItem": {
      "title": "Inventory Item",
      "description": "Items in HQ stock",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "category": { "type": "string", "enum": ["medical", "rescue", "shelter", "rations", "vehicles"] },
        "quantity": { "type": "number" },
        "unit": { "type": "string" },
        "lastUpdated": { "type": "string", "format": "date-time" },
        "minThreshold": { "type": "number" }
      },
      "required": ["name", "category", "quantity", "unit", "lastUpdated", "minThreshold"]
    },
    "IncidentPhoto": {
      "title": "Incident Photo",
      "description": "Evidence from the field",
      "type": "object",
      "properties": {
        "url": { "type": "string" },
        "caption": { "type": "string" },
        "uploadedBy": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "location": {
          "type": "object",
          "properties": {
            "lat": { "type": "number" },
            "lng": { "type": "number" }
          },
          "required": ["lat", "lng"]
        },
        "disasterZone": { "type": "string" }
      },
      "required": ["url", "uploadedBy", "timestamp", "location", "disasterZone"]
    }
  },
  "firestore": {
    "/users/{uid}": { "schema": "User", "description": "User profiles" },
    "/resources/{resourceId}": { "schema": "Resource", "description": "NDRF resource tracking" },
    "/alerts/{alertId}": { "schema": "EmergencyAlert", "description": "Broadcasted emergency alerts" },
    "/requests/{requestId}": { "schema": "ResourceRequest", "description": "Field resource requirements and transfer requests" },
    "/inventory/{itemId}": { "schema": "InventoryItem", "description": "HQ global inventory stock tracking" },
    "/photos/{photoId}": { "schema": "IncidentPhoto", "description": "Field evidence and damage assessment photos" },
    "/incidents/{incidentId}": { "schema": "DisasterIncident", "description": "Global active disaster events and epicenters" }
  }
}

